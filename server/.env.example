# 服务端口（默认 3000）
PORT=3000

# 数据库连接（支持 SQLite 和 PostgreSQL）
# 留空使用 SQLite（自动创建 data/agenthub.db，适合个人/小规模使用）
# 填 PostgreSQL 连接串适合生产环境/多实例部署
#
# SQLite 示例（默认，无需配置）：
# DATABASE_URL=
#
# PostgreSQL 示例：
# DATABASE_URL=postgres://postgres:password@localhost:5432/agenthub
DATABASE_URL=

# PostgreSQL 独立配置（当 DATABASE_URL 留空时使用，优先级高于 DATABASE_URL）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=agenthub

# JWT 密钥（生产环境务必修改）
JWT_SECRET=agenthub-jwt-secret-2026-change-this

# 前端构建时的 API 地址（留空使用相对路径 /api）
# 格式：http://你的域名:3000
VITE_API_URL=
